rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helpers
    function isAdmin() {
      return request.auth != null && request.auth.token.role == 'admin';
    }
    // Paid (Pro/Enterprise, active) users — gates access to the lead/license data.
    function isPaid() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.plan in ['pro', 'enterprise']
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.planStatus == 'active';
    }
    function canReadData() {
      return isAdmin() || isPaid();
    }

    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      // Admins can read any user doc
      allow read: if isAdmin();
    }
    match /licenses/{licenseNumber} {
      // Paid/admin users can read; writes are admin-SDK only (ingest)
      allow read: if canReadData();
      allow write: if false;
    }
    match /establishments/{id} {
      // Paid/admin users can read enriched records
      allow read: if canReadData();
      // Writes only via admin SDK or admin-claimed users
      allow write: if isAdmin();
    }
    match /leads/{id} {
      // Paid/admin: full access. Free trial: Travis County + records 30+ days old
      // only (the query must constrain county + recordDate, enforced here).
      allow read: if canReadData()
        || (request.auth != null
            && resource.data.county == 'Travis'
            && resource.data.recordDate is timestamp
            && resource.data.recordDate < request.time - duration.value(30, 'd'));
      allow write: if isAdmin();
      // CRM subcollections: authenticated users can read/manage contacts + activity.
      match /contacts/{contactId} {
        allow read, write: if request.auth != null;
      }
      match /activities/{activityId} {
        allow read, write: if request.auth != null;
      }
    }
    // Integration settings (webhook config) — admin only.
    match /settings/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    // Operator (hospitality group) registry — authed read (needed for search), admin write.
    match /operators/{operatorId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    match /alerts/{alertId} {
      allow get: if request.auth != null && resource.data.userId == request.auth.uid;
      allow list: if request.auth != null;
      allow write: if false;
    }
    match /exports/{exportId} {
      allow get: if request.auth != null && resource.data.userId == request.auth.uid;
      allow list: if request.auth != null;
      allow write: if false;
    }
    match /runs/{runId} {
      allow read, write: if false;
    }

    // Admin-only collections
    match /system/{document=**} {
      allow read, write: if isAdmin();
    }
    match /comptroller_unmatched/{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
